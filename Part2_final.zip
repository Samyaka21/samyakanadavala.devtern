      "source": [
        "import pandas as pd\n",
        "import os\n",
        "import zipfile # Import zipfile module\n",
        "\n",
        "# Define the path where your folders are located\n",
        "# If you uploaded a folder named 'bbc', change the path below accordingly\n",
        "data_dir = 'bbc'\n",
        "categories = ['business', 'entertainment', 'politics', 'sport', 'tech']\n",
        "\n",
        "# Check if the 'bbc' directory exists. If not, try to unzip the provided dataset.\n",
        "if not os.path.exists(data_dir):\n",
        "    zip_file_path = '/content/datasets_coursework1.zip' # Corrected path to the zip file\n",
        "    if os.path.exists(zip_file_path):\n",
        "        print(f\"'{data_dir}' directory not found. Attempting to unzip '{zip_file_path}'...\")\n",
        "        with zipfile.ZipFile(zip_file_path, 'r') as zip_ref:\n",
        "            zip_ref.extractall('.') # Extract to the current directory, which should create 'bbc'\n",
        "        print(f\"'{zip_file_path}' unzipped successfully. Checking for '{data_dir}' again.\")\n",
        "    else:\n",
        "        print(f\"Error: '{data_dir}' directory not found and '{zip_file_path}' does not exist. Please ensure the data is available.\")\n",
        "        # If the zip file is also not found, the script cannot proceed with data loading.\n",
        "        # For now, we'll let the DataFrame be empty and handle it gracefully below.\n",
        "else:\n",
        "    print(f\"'{data_dir}' directory found.\")\n",
        "\n",
        "data = []\n",
        "\n",
        "for category in categories:\n",
        "    folder_path = os.path.join(data_dir, category)\n",
        "    if os.path.exists(folder_path):\n",
        "        for file_name in os.listdir(folder_path):\n",
        "            if file_name.endswith(\".txt\"):\n",
        "                file_path = os.path.join(folder_path, file_name)\n",
        "                # Using 'latin-1' encoding to avoid errors with special characters in news text\n",
        "                try:\n",
        "                    with open(file_path, 'r', encoding='latin-1') as f:\n",
        "                        content = f.read()\n",
        "                        data.append({'text': content, 'category': category})\n",
        "                except Exception as e:\n",
        "                    print(f\"Error reading file {file_path}: {e}\")\n",
        "    else:\n",
        "        print(f\"Warning: Category folder '{folder_path}' not found.\")\n",
        "\n",
        "# Create the DataFrame\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "# Verify the load\n",
        "print(f\"Total documents loaded: {len(df)}\")\n",
        "# Only attempt to print value counts if the DataFrame is not empty\n",
        "if not df.empty:\n",
        "    print(df['category'].value_counts())\n",
        "else:\n",
        "    print(\"DataFrame is empty, cannot compute 'category' value counts.\")\n",
        "print(\"\\nFirst 5 rows:\")\n",
        "print(df.head())"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "\n",
        "# 1. Split the data into Training (80%) and Test (20%) sets\n",
        "# We use 'stratify' to ensure each category is equally represented in both sets\n",
        "X_train_raw, X_test_raw, y_train, y_test = train_test_split(\n",
        "    df['text'],\n",
        "    df['category'],\n",
        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=df['category']\n",
        ")\n",
        "\n",
        "# 2. Initialize the TF-IDF Vectorizer\n",
        "# stop_words='english' removes common filler words like 'and', 'the', etc.\n",
        "# max_features=5000 limits the vocabulary to the top 5000 most important words\n",
        "tfidf = TfidfVectorizer(stop_words='english', max_features=5000)\n",
        "\n",
        "# 3. Fit and transform the training data, and transform the test data\n",
        "X_train = tfidf.fit_transform(X_train_raw)\n",
        "X_test = tfidf.transform(X_test_raw)\n",
        "\n",
        "print(f\"Training data shape: {X_train.shape}\")\n",
        "print(f\"Test data shape: {X_test.shape}\")"
      ],
      "metadata": {
        "colab": {
