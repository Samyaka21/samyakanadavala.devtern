    {
      "cell_type": "code",
      "source": [
        "from sklearn.svm import LinearSVC\n",
        "from sklearn.metrics import accuracy_score, classification_report\n",
        "\n",
        "# 1. Initialize and Train the Linear SVM\n",
        "# LinearSVC is generally faster and better suited for text than the standard SVC\n",
        "svm_bbc = LinearSVC(random_state=42, C=1.0)\n",
        "svm_bbc.fit(X_train, y_train)\n",
        "\n",
        "# 2. Predict on the Test Set\n",
        "y_pred_svm = svm_bbc.predict(X_test)\n",
        "\n",
        "# 3. Evaluate Performance\n",
        "svm_accuracy = accuracy_score(y_test, y_pred_svm)\n",
        "print(f\"SVM Accuracy: {svm_accuracy:.4f}\")\n",
        "print(\"\\nDetailed Classification Report (SVM):\")\n",
        "print(classification_report(y_test, y_pred_svm))"
      ],
      "metadata": {
