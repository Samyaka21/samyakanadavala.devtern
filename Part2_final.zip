    {
      "cell_type": "markdown",
      "metadata": {
        "id": "6917a0bb"
      },
      "source": [
        "Once you identify the correct path for `datasets_coursework1 (2).zip` (or `datasets_coursework1.zip` as seen in the kernel state), you can update the `zip_file_path` variable in the first code cell accordingly. It seems like the correct path might be `/content/datasets_coursework1.zip` based on the available files."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.metrics import accuracy_score, classification_report, confusion_matrix\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Initialize and Train the Random Forest\n",
        "# n_estimators=100 means we are using 100 decision trees\n",
        "rf_bbc = RandomForestClassifier(n_estimators=100, random_state=42)\n",
        "rf_bbc.fit(X_train, y_train)\n",
        "\n",
        "# 2. Predict on the Test Set\n",
        "y_pred_rf = rf_bbc.predict(X_test)\n",
        "\n",
        "# 3. Evaluate Performance\n",
        "accuracy = accuracy_score(y_test, y_pred_rf)\n",
        "print(f\"Random Forest Accuracy: {accuracy:.4f}\")\n",
        "print(\"\\nDetailed Classification Report:\")\n",
        "print(classification_report(y_test, y_pred_rf))\n",
        "\n",
        "# 4. Optional: Visualize the Confusion Matrix\n",
        "cm = confusion_matrix(y_test, y_pred_rf)\n",
        "plt.figure(figsize=(10,7))\n",
        "sns.heatmap(cm, annot=True, fmt='d', xticklabels=rf_bbc.classes_, yticklabels=rf_bbc.classes_)\n",
        "plt.xlabel('Predicted')\n",
        "plt.ylabel('Actual')\n",
        "plt.title('Confusion Matrix - Random Forest')\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
